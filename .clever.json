{
  "build": {
    "type": "nodejs",
    "build-command": "cd server && npm install && npm run build",
    "build-env": {
      "NODE_ENV": "production"
    }
  },
  "deploy": {
    "type": "nodejs",
    "start-command": "cd server && node dist/index.js",
    "env": {
      "NODE_ENV": "production"
    }
  }
}
