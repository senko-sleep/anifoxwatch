# Shared env (loaded in dev + build). For local full-stack dev, prefer `.env.development`
# with `VITE_USE_LOCAL_API=true` so the browser hits Vite’s `/api/*` proxy (not `:3001` directly).
# Uncomment only for client-only dev against a fixed API host:
# VITE_API_URL=http://localhost:3001

# HiAnime REST proxy URL for streaming fallback
HIANIME_REST_URL=https://anifoxwatch-api.anya-bot.workers.dev

# Enable Puppeteer for Miruro to bypass Cloudflare challenges
ENABLE_MIRO_PUPPETEER=1

# PostgreSQL Database URL (for caching anime data, watch history, etc.)
# Set your Postgres URL here (e.g., from Vercel Postgres, Neon, Supabase, etc.)
POSTGRES_URL=
