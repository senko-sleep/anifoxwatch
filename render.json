{
  "build": {
    "env": {
      "NODE_ENV": "production",
      "NODE_OPTIONS": "--max-old-space-size=256 --expose-gc"
    }
  },
  "services": [
    {
      "type": "web",
      "name": "anifoxwatch-api",
      "runtime": "node",
      "plan": "free",
      "buildCommand": "cd server && npm install && npm run build",
      "startCommand": "cd server && npm run start:render",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "NODE_OPTIONS",
          "value": "--max-old-space-size=256 --expose-gc --disable-warnings"
        },
        {
          "key": "ENABLE_MIRO_PUPPETEER",
          "value": "0"
        }
      ],
      "disk": {
        "name": "cache",
        "mountPath": "/tmp/cache",
        "sizeGB": 1
      }
    },
    {
      "type": "web",
      "name": "anifoxwatch-web",
      "runtime": "static",
      "buildCommand": "npm install && npm run build",
      "staticPublishPath": "dist",
      "routes": [
        {
          "path": "/api/*",
          "destination": "anifoxwatch-api"
        }
      ]
    }
  ]
}
