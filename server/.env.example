# Hentai Source Proxy Configuration
# Use these environment variables to route hentai source requests through a proxy
# This is useful when hentai sources are geo-blocked in your region

# Proxy server hostname or IP address
HENTAI_PROXY_HOST=proxy.example.com

# Proxy server port
HENTAI_PROXY_PORT=8080

# Proxy authentication (optional, only if your proxy requires username/password)
HENTAI_PROXY_USER=your_username
HENTAI_PROXY_PASS=your_password

# Example configurations:
# For a free HTTP proxy: HENTAI_PROXY_HOST=free-proxy.example.com, HENTAI_PROXY_PORT=3128
# For a SOCKS5 proxy: Use a SOCKS5-to-HTTP proxy converter or configure axios accordingly
# For a paid proxy service: Use the service's provided host, port, and credentials
