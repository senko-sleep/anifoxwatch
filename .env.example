# Production / `vite build` / `vite preview` — backend base URL (no trailing slash)
VITE_API_URL=https://your-api.example.com

# ─── Vite dev — copy to `.env.development` ───
# Full stack (recommended): `npm run dev` runs API + web. Use local proxy:
# VITE_USE_LOCAL_API=true
#
# Client-only against a remote API:
# VITE_USE_LOCAL_API=false
# VITE_API_URL=https://your-deployed-api.example.com
#
# Optional absolute override
# VITE_DEV_API_URL=http://127.0.0.1:3001
