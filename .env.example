# Production / `vite build` / `vite preview` — backend base URL (no trailing slash)
VITE_API_URL=https://your-api.example.com
# Optional: secondary API host used only if the primary stream request fails (404/5xx/timeouts)
# VITE_API_FALLBACK_URL=https://your-vercel-app.vercel.app

# PostgreSQL Database URL (for caching anime data, watch history, etc.)
POSTGRES_URL=postgresql://username:password@host:port/database

# ─── Vite dev — copy to `.env.development` ───
# Full stack (recommended): `npm run dev` runs API + web. Use local proxy:
# VITE_USE_LOCAL_API=true
# When `VITE_USE_LOCAL_API=true`, root `.env` values like `VITE_API_URL` are ignored
# so the browser always uses same-origin `/api/*` (Vite proxies to the API).
#
# Proxy target for `/api` + `/health` (must match Express `PORT`, default 3001):
# VITE_API_PROXY_PORT=3001
# or full URL: VITE_API_PROXY_TARGET=http://127.0.0.1:3001
#
# Client-only against a remote API:
# VITE_USE_LOCAL_API=false
# VITE_API_URL=https://your-deployed-api.example.com
#
# Optional absolute override
# VITE_DEV_API_URL=http://127.0.0.1:3001
