# Production API (baked in at `vite build`). Browser calls this host directly.
# Node API on Vercel (`vercel.json` routes /api/* → server/src/index.ts).
# Set HIANIME_REST_URL in the Vercel project (e.g. https://aniwatch-api-coral-seven.vercel.app) for HiAnime REST proxy.
VITE_API_URL=https://anifoxwatch.vercel.app
# Shown on /health (optional upstream probe; browser must be allowed by that API’s CORS).
VITE_ANIWATCH_API_URL=https://aniwatch-api-coral-seven.vercel.app
