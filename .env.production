# Production API (baked in at `vite build`). Browser calls this host directly.
# The Worker implements /api/anime/* and /api/stream/*; HiAnime upstream is optional
# HTTP (HIANIME_REST_URL in server/wrangler.toml) — e.g. your Vercel aniwatch-api.
# Primary: Cloudflare Workers (edge, CORS). Fallback: Render — see src/lib/api-config.ts.
VITE_API_URL=https://anifoxwatch-api.anya-bot.workers.dev
# Shown on /health (optional upstream probe; browser must be allowed by that API’s CORS).
VITE_ANIWATCH_API_URL=https://aniwatch-api-coral-seven.vercel.app
