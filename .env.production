# Production API (baked in at `vite build`).
# For Vercel deployment, leave this empty to use same-origin (recommended).
# If you deploy the API separately, set the full origin URL (e.g. https://your-api.example.com).
VITE_API_URL=https://app-82ae23d3-5750-4b13-9cc6-9a9ad55a2b17.cleverapps.io/
# Optional secondary API host to try when the primary stream request fails (404/5xx/timeouts).
# Useful if a stale `VITE_API_URL` was baked into a build, or during migrations.
# VITE_API_FALLBACK_URL=https://your-vercel-app.vercel.app
# Shown on /health (optional upstream probe; browser must be allowed by that API's CORS).
VITE_ANIWATCH_API_URL=https://aniwatch-api-coral-seven.vercel.app
