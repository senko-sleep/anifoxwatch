# Use the local Express API via Vite proxy during development.
# The browser will hit http://localhost:8081/api, which Vite proxies to http://127.0.0.1:3001.
VITE_USE_LOCAL_API=true
# VITE_DEV_API_URL=http://localhost:3001

# Optional Vite proxy mode: set VITE_USE_LOCAL_API=true and remove VITE_DEV_API_URL.
# If you run the API on another port while proxying, set ONE of:
# VITE_API_PROXY_PORT=3002
# VITE_API_PROXY_TARGET=http://127.0.0.1:3002

# Fallback: if you want to skip running the local server and use remote API:
# VITE_USE_LOCAL_API=false
# VITE_API_URL=https://anifoxwatch-api.anya-bot.workers.dev
