# `npm run dev` runs API + Vite — use same-origin proxy (see vite.config.ts → /api → :3001)
VITE_USE_LOCAL_API=true

# If you only run `npm run dev:client` and want a remote API instead:
# VITE_USE_LOCAL_API=false
# VITE_API_URL=https://your-api.example.com

# Optional absolute override (rare)
# VITE_DEV_API_URL=http://127.0.0.1:3001
